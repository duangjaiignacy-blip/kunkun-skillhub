{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kunkun",
  "version": "0.1.0",
  "identifier": "com.kunkun.skillhub",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "kunkun · skill管理平台",
        "width": 1180,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.png", "icons/icon.icns"]
  }
}
